{
  "schema_version": "1.0",
  "tiers": {
    "fast": {
      "description": "Trivial tasks: formatting, typo fixes, short classification, data extraction",
      "provider": "google",
      "model": "gemini-2.0-flash",
      "max_tokens": 1024,
      "cost_per_1m_input": 0.0,
      "cost_per_1m_output": 0.0
    },
    "standard": {
      "description": "Medium tasks: summarization, content rewriting, translation, moderate analysis",
      "provider": "google",
      "model": "gemini-2.0-flash",
      "max_tokens": 4096,
      "cost_per_1m_input": 0.15,
      "cost_per_1m_output": 0.60
    },
    "deep": {
      "description": "Complex reasoning: strategy, code generation, creative writing, multi-step analysis. Matches Cowork's model.",
      "provider": "anthropic",
      "model": "claude-opus-4-7",
      "max_tokens": 32768,
      "cost_per_1m_input": 5.00,
      "cost_per_1m_output": 25.00
    }
  },
  "routing_rules": {
    "format":            "fast",
    "classify":          "fast",
    "extract":           "fast",
    "typo_fix":          "fast",
    "summarize":         "standard",
    "rewrite":           "standard",
    "translate":         "standard",
    "draft":             "standard",
    "analyze":           "deep",
    "strategize":        "deep",
    "generate_code":     "deep",
    "creative_write":    "deep",
    "debug":             "deep",
    "complex_reasoning": "deep",
    "general":           "deep"
  },
  "fallback_tier": "standard",
  "providers": {
    "google": {
      "env_key": "GOOGLE_API_KEY",
      "base_url": "https://generativelanguage.googleapis.com/v1beta"
    },
    "anthropic": {
      "env_key": "ANTHROPIC_API_KEY",
      "base_url": "https://api.anthropic.com/v1"
    },
    "openai": {
      "env_key": "OPENAI_API_KEY",
      "base_url": "https://api.openai.com/v1"
    },
    "openrouter": {
      "env_key": "OPENROUTER_API_KEY",
      "base_url": "https://openrouter.ai/api/v1"
    }
  }
}
